{
  "name": "rs-dpm-planner",
  "version": "0.0.0",
  "scripts": {
    "game-data:bundle": "node scripts/generate-game-data-bundle.mjs",
    "predev": "npm run game-data:bundle",
    "ng": "ng",
    "dev": "ng serve",
    "predev:e2e": "npm run game-data:bundle",
    "dev:e2e": "ng serve --host 127.0.0.1 --port 4201",
    "prestart": "npm run game-data:bundle",
    "start": "ng serve",
    "prebuild": "npm run game-data:bundle",
    "build": "ng build",
    "prewatch": "npm run game-data:bundle",
    "watch": "ng build --watch --configuration development",
    "pretest": "npm run game-data:bundle",
    "test": "ng test --watch=false",
    "test:watch": "ng test --watch",
    "check:boundaries": "node scripts/check-core-feature-boundary.mjs",
    "e2e": "playwright test",
    "lint": "eslint ."
  },
  "private": true,
  "packageManager": "npm@11.12.0",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@vercel/analytics": "^2.0.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.3",
    "@angular/cli": "^21.2.3",
    "@angular/compiler-cli": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "angular-eslint": "^21.3.1",
    "eslint": "^10.1.0",
    "jsdom": "^28.0.0",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.0.8"
  }
}
